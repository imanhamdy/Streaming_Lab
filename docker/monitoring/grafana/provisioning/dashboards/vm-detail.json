{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Détail complet par VM — sélectionner la VM via le menu déroulant",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [ { "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" } ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      },
      "gridPos": { "h": 3, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Statut",
      "type": "stat",
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "up{instance=\"$vm\"}", "legendFormat": "", "refId": "A" } ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 80 }, { "color": "red", "value": 95 } ] },
          "unit": "percent", "min": 0, "max": 100
        }
      },
      "gridPos": { "h": 3, "w": 4, "x": 4, "y": 0 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "CPU",
      "type": "stat",
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "100 - (avg by(instance)(rate(node_cpu_seconds_total{mode=\"idle\",instance=\"$vm\"}[5m])) * 100)", "legendFormat": "", "refId": "A" } ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 80 }, { "color": "red", "value": 90 } ] },
          "unit": "percent", "min": 0, "max": 100
        }
      },
      "gridPos": { "h": 3, "w": 4, "x": 8, "y": 0 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "RAM",
      "type": "stat",
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "(1 - (node_memory_MemAvailable_bytes{instance=\"$vm\"} / node_memory_MemTotal_bytes{instance=\"$vm\"})) * 100", "legendFormat": "", "refId": "A" } ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 3, "w": 4, "x": 12, "y": 0 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "RAM totale",
      "type": "stat",
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "node_memory_MemTotal_bytes{instance=\"$vm\"}", "legendFormat": "", "refId": "A" } ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "unit": "s"
        }
      },
      "gridPos": { "h": 3, "w": 4, "x": 16, "y": 0 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Uptime",
      "type": "stat",
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "node_time_seconds{instance=\"$vm\"} - node_boot_time_seconds{instance=\"$vm\"}", "legendFormat": "", "refId": "A" } ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 3, "w": 4, "x": 20, "y": 0 },
      "id": 6,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "CPU cores",
      "type": "stat",
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "count(node_cpu_seconds_total{instance=\"$vm\",mode=\"idle\"})", "legendFormat": "", "refId": "A" } ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 3 },
      "id": 200,
      "title": "⚙️ CPU détail",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never" },
          "max": 100, "min": 0, "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 80 }, { "color": "red", "value": 95 } ] }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 10,
      "options": { "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "title": "CPU Usage global",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "100 - (avg by(instance)(rate(node_cpu_seconds_total{mode=\"idle\",instance=\"$vm\"}[5m])) * 100)", "legendFormat": "CPU total", "refId": "A" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineInterpolation": "smooth", "lineWidth": 1, "showPoints": "never", "stacking": { "group": "A", "mode": "normal" } },
          "max": 100, "min": 0, "unit": "percent"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 11,
      "options": { "legend": { "calcs": ["mean"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "title": "CPU par mode (user / system / iowait…)",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "avg by(mode)(rate(node_cpu_seconds_total{instance=\"$vm\",mode!=\"idle\"}[5m])) * 100", "legendFormat": "{{mode}}", "refId": "A" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 12 },
      "id": 201,
      "title": "🧠 RAM détail",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never", "stacking": { "group": "A", "mode": "normal" } },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 13 },
      "id": 20,
      "options": { "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "title": "RAM — utilisée / buffers / cache / libre",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "node_memory_MemTotal_bytes{instance=\"$vm\"} - node_memory_MemFree_bytes{instance=\"$vm\"} - node_memory_Buffers_bytes{instance=\"$vm\"} - node_memory_Cached_bytes{instance=\"$vm\"}", "legendFormat": "Utilisée", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "node_memory_Buffers_bytes{instance=\"$vm\"}", "legendFormat": "Buffers", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "node_memory_Cached_bytes{instance=\"$vm\"}", "legendFormat": "Cache", "refId": "C" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "node_memory_MemFree_bytes{instance=\"$vm\"}", "legendFormat": "Libre", "refId": "D" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "id": 202,
      "title": "💾 Disque détail",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never" },
          "unit": "Bps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "id": 30,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "title": "I/O Disque — lecture / écriture",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(node_disk_read_bytes_total{instance=\"$vm\",device!~\"sr.*\"}[5m])", "legendFormat": "Lecture {{device}}", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(node_disk_written_bytes_total{instance=\"$vm\",device!~\"sr.*\"}[5m])", "legendFormat": "Écriture {{device}}", "refId": "B" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 75 }, { "color": "red", "value": 90 } ] },
          "unit": "percent", "min": 0, "max": 100
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "id": 31,
      "options": { "displayMode": "basic", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }, "showUnfilled": true },
      "title": "Partitions — utilisation actuelle",
      "type": "bargauge",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "(1 - (node_filesystem_avail_bytes{instance=\"$vm\",fstype!~\"tmpfs|overlay|squashfs\"} / node_filesystem_size_bytes{instance=\"$vm\",fstype!~\"tmpfs|overlay|squashfs\"})) * 100", "legendFormat": "{{mountpoint}}", "instant": true, "refId": "A" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "id": 203,
      "title": "🌐 Réseau détail",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never" },
          "unit": "Bps"
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*TX.*" }, "properties": [ { "id": "custom.transform", "value": "negative-Y" } ] }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 31 },
      "id": 40,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "title": "Trafic réseau RX (+) / TX (−)",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(node_network_receive_bytes_total{instance=\"$vm\",device!~\"lo|docker.*|veth.*\"}[5m])", "legendFormat": "RX {{device}}", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(node_network_transmit_bytes_total{instance=\"$vm\",device!~\"lo|docker.*|veth.*\"}[5m])", "legendFormat": "TX {{device}}", "refId": "B" }
      ]
    }

  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["infra", "vm", "detail"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Datasource"
      },
      {
        "current": { "selected": false, "text": "vm-principal", "value": "vm-principal" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(up, instance)",
        "hide": 0,
        "includeAll": false,
        "name": "vm",
        "query": "label_values(up, instance)",
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "label": "VM"
      }
    ]
  },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "Europe/Paris",
  "title": "VM — Détail",
  "uid": "vm-detail",
  "version": 1
}
