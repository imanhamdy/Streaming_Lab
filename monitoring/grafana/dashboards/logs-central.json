{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Logs centralisés — syslog, auth, Suricata sur les 3 VMs",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "📊 Volume de logs",
      "type": "row"
    },

    {
      "datasource": { "type": "loki", "uid": "${lokids}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "fillOpacity": 80, "gradientMode": "none", "lineWidth": 1, "showPoints": "never", "spanNulls": false, "stacking": { "group": "A", "mode": "normal" } },
          "unit": "short"
        }
      },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Volume de logs par VM",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "loki", "uid": "${lokids}" }, "expr": "sum by(host)(count_over_time({host=\"vm-principal\"}[$__interval]))", "legendFormat": "vm-principal", "refId": "A" },
        { "datasource": { "type": "loki", "uid": "${lokids}" }, "expr": "sum by(host)(count_over_time({host=\"vm-dns\"}[$__interval]))", "legendFormat": "vm-dns", "refId": "B" },
        { "datasource": { "type": "loki", "uid": "${lokids}" }, "expr": "sum by(host)(count_over_time({host=\"vm-backup\"}[$__interval]))", "legendFormat": "vm-backup", "refId": "C" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 },
      "id": 101,
      "title": "📋 Logs système (syslog)",
      "type": "row"
    },

    {
      "datasource": { "type": "loki", "uid": "${lokids}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 9 },
      "id": 10,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "title": "Syslog — ${vm}",
      "type": "logs",
      "targets": [
        { "datasource": { "type": "loki", "uid": "${lokids}" }, "expr": "{job=\"syslog\",host=~\"$vm\"}", "legendFormat": "", "refId": "A" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "id": 102,
      "title": "🔐 Authentification (auth.log)",
      "type": "row"
    },

    {
      "datasource": { "type": "loki", "uid": "${lokids}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "fillOpacity": 80, "lineWidth": 1, "stacking": { "group": "A", "mode": "normal" } },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 20 },
      "id": 20,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "title": "Tentatives SSH échouées",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "loki", "uid": "${lokids}" }, "expr": "sum by(host)(count_over_time({job=\"auth\"} |= \"Failed password\" [$__interval]))", "legendFormat": "{{host}}", "refId": "A" }
      ]
    },

    {
      "datasource": { "type": "loki", "uid": "${lokids}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "fillOpacity": 80, "lineWidth": 1, "stacking": { "group": "A", "mode": "normal" } },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 20 },
      "id": 21,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "title": "Connexions SSH réussies",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "loki", "uid": "${lokids}" }, "expr": "sum by(host)(count_over_time({job=\"auth\"} |= \"Accepted\" [$__interval]))", "legendFormat": "{{host}}", "refId": "A" }
      ]
    },

    {
      "datasource": { "type": "loki", "uid": "${lokids}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 26 },
      "id": 22,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "title": "Auth logs — ${vm}",
      "type": "logs",
      "targets": [
        { "datasource": { "type": "loki", "uid": "${lokids}" }, "expr": "{job=\"auth\",host=~\"$vm\"}", "legendFormat": "", "refId": "A" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "id": 103,
      "title": "🛡️ Suricata IDS",
      "type": "row"
    },

    {
      "datasource": { "type": "loki", "uid": "${lokids}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "fillOpacity": 80, "lineWidth": 1, "stacking": { "group": "A", "mode": "normal" } },
          "unit": "short"
        }
      },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 35 },
      "id": 30,
      "options": { "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Alertes Suricata par VM",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "loki", "uid": "${lokids}" }, "expr": "sum by(host)(count_over_time({job=\"suricata\",host=~\"$vm\"} |= \"ALERT\" [$__interval]))", "legendFormat": "{{host}}", "refId": "A" }
      ]
    },

    {
      "datasource": { "type": "loki", "uid": "${lokids}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 42 },
      "id": 31,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "title": "Alertes Suricata — ${vm}",
      "type": "logs",
      "targets": [
        { "datasource": { "type": "loki", "uid": "${lokids}" }, "expr": "{job=\"suricata\",host=~\"$vm\"} |= \"ALERT\"", "legendFormat": "", "refId": "A" }
      ]
    }

  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["logs", "loki", "security"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "lokids",
        "options": [],
        "query": "loki",
        "refresh": 1,
        "type": "datasource",
        "label": "Loki"
      },
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "loki", "uid": "${lokids}" },
        "definition": "label_values(host)",
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "name": "vm",
        "query": "label_values(host)",
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "label": "VM"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "Europe/Paris",
  "title": "Logs — Vue centralisée",
  "uid": "logs-central",
  "version": 1
}
